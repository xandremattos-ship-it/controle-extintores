rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function profileExists() {
      return signedIn()
        && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        );
    }

    function profile() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data;
    }

    function activeUser() {
      return profileExists()
        && profile().get('active', false) == true
        && profile().get('status', 'ATIVO') == 'ATIVO';
    }

    function isAdmin() {
      return activeUser()
        && profile().role == 'ADMINISTRADOR';
    }

    function isInspector() {
      return activeUser()
        && profile().role == 'INSPETOR';
    }

    function isViewer() {
      return activeUser()
        && profile().role == 'VISUALIZADOR';
    }

    function sameUsina(usina) {
      return activeUser()
        && profile().usina is string
        && profile().usina == usina;
    }

    function validSelfRegistration(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll([
          'uid',
          'name',
          'email',
          'role',
          'usina',
          'status',
          'active',
          'requestedAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'role',
          'usina',
          'status',
          'active',
          'requestedAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 100
        && request.auth.token.email is string
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == ''
        && request.resource.data.usina == ''
        && request.resource.data.status == 'PENDENTE'
        && request.resource.data.active == false
        && request.resource.data.requestedAt == request.time
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validOwnNotificationState(userId) {
      return activeUser()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll([
          'uid',
          'readIds',
          'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'uid',
          'readIds',
          'updatedAt',
          'prunedAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.readIds is list
        && request.resource.data.readIds.size() <= 500;
    }

    // ========================================================
    // USUÁRIOS
    // ========================================================

    match /users/{userId} {
      allow get: if signedIn()
        && (
          request.auth.uid == userId
          || isAdmin()
        );

      allow list: if isAdmin();

      allow create: if isAdmin()
        || validSelfRegistration(userId);

      allow update, delete: if isAdmin();
    }

    // ========================================================
    // ESTADO DAS NOTIFICAÇÕES
    // ========================================================

    match /notificationStates/{userId} {
      allow get: if activeUser()
        && request.auth.uid == userId;

      allow create, update: if validOwnNotificationState(userId);

      allow delete: if activeUser()
        && request.auth.uid == userId;
    }

    // ========================================================
    // CONFIGURAÇÕES
    // ========================================================

    match /settings/{document=**} {
      allow read: if activeUser();
      allow write: if isAdmin();
    }

    // ========================================================
    // EXTINTORES
    // ========================================================

    match /extinguishers/{extinguisherId} {
      allow read: if isAdmin()
        || sameUsina(resource.data.usina);

      allow create: if isAdmin()
        || (
          isInspector()
          && request.resource.data.usina == profile().usina
        );

      allow update: if isAdmin()
        || (
          isInspector()
          && resource.data.usina == profile().usina
          && request.resource.data.usina == profile().usina
        );

      allow delete: if isAdmin()
        || (
          isInspector()
          && resource.data.usina == profile().usina
        );
    }

    // ========================================================
    // INSPEÇÕES E TRATATIVAS
    // ========================================================

    match /inspections/{inspectionId} {
      allow read: if isAdmin()
        || sameUsina(resource.data.usina);

      allow create: if isAdmin()
        || (
          isInspector()
          && request.resource.data.usina == profile().usina
        );

      allow update: if isAdmin()
        || (
          isInspector()
          && resource.data.usina == profile().usina
          && request.resource.data.usina == profile().usina
        );

      allow delete: if isAdmin();
    }

    // ========================================================
    // DADOS ANTIGOS
    // ========================================================

    match /appData/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
